<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Students in <%= classInfo.class_name %></title>

    <!-- project styles / icons (match classes.ejs & addClass.ejs) -->
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/mobile.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://demos.creative-tim.com/notus-js/assets/styles/tailwind.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="/js/auth-jwt.js"></script>
    <style>
        html, body { height: 100%; margin: 0; padding: 0; }
        body { min-height: 100vh; display: flex; flex-direction: column; }
        main, .modern-container { flex: 1 0 auto; }
        footer { flex-shrink: 0; }

        .modern-container {
            max-width: 1200px;
            margin: 48px auto 24px auto;
            padding: 2.0rem 1.8rem;
            background: #fff;
            border-radius: 18px;
            box-shadow: 0 4px 24px rgba(44,62,80,0.10);
            border: 1px solid #eaecef;
            animation: fadeIn 0.45s;
        }
        .modern-title {
            font-size: 1.6rem;
            font-weight: 700;
            color: #2375D8;
            letter-spacing: .4px;
            display:flex;
            align-items:center;
            gap:.6rem;
        }
        .modern-sub {
            color: #6b7280;
            font-size: 0.95rem;
        }

        .modern-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 1.2rem;
            background: #f9fafb;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(44,62,80,0.06);
        }
        .modern-table th, .modern-table td { padding: 0.9rem 1rem; text-align: left; font-size: .95rem; }
        .modern-table th { background: #2375D8; color: #fff; font-weight: 600; font-size: .95rem; }
        .modern-table tbody tr { background: #fff; transition: background .12s; }
        .modern-table tbody tr:hover { background: #eef6ff; }
        .modern-table td { border-bottom: 1px solid #eef2f7; color: #374151; }

        .modern-btn-secondary {
            background: #eef2f7;
            color: #374151;
            font-weight: 600;
            padding: .6rem .9rem;
            border-radius: 8px;
            text-decoration: none;
            display: inline-flex;
            align-items:center;
            gap:.5rem;
            border: 1px solid rgba(15,23,42,.04);
        }
        .modern-btn-secondary:hover { background:#e2e8f0; color:#2375D8; transform: translateY(-1px); }

        .modern-btn-primary {
            background: linear-gradient(90deg, #2375D8 0%, #0c9083 100%);
            color: #fff;
            font-weight: 700;
            padding: .6rem .9rem;
            border-radius: 8px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: .5rem;
            border: none;
            box-shadow: 0 4px 16px rgba(36,117,216,0.10);
            transition: background 0.2s, transform 0.15s;
            cursor: pointer;
        }
        .modern-btn-primary:hover {
            background: linear-gradient(90deg, #0c9083 0%, #2375D8 100%);
            transform: translateY(-2px) scale(1.03);
            box-shadow: 0 8px 24px rgba(36,117,216,0.18);
        }

        .badge-paid { background:#e6fff6; color:#0f766e; padding:4px 8px; border-radius:999px; font-weight:600; display:inline-block; }
        .badge-unpaid { background:#fff7ed; color:#92400e; padding:4px 8px; border-radius:999px; font-weight:600; display:inline-block; }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(12px);} to { opacity: 1; transform: translateY(0);} }
    </style>
</head>

<body>
    <%- include('../shared/header') %>

    <main>
        <div class="modern-container">
            <div style="display:flex; justify-content:space-between; align-items:center; gap:1rem; margin-bottom: .6rem;">
                <div>
                    <div class="modern-title">
                        <i class="fas fa-user-graduate"></i>
                        <span id="class_title">Students in Class</span>
                    </div>
                    <div class="modern-sub" id="class_info" style="margin-top:6px;">
                        Loading...
                    </div>
                </div>

                <div style="display:flex; align-items:center; gap:.6rem;">
                    <a href="/classes" class="modern-btn-primary"><i class="fas fa-arrow-left"></i> Back to Classes</a>
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="modern-table">
                    <thead>
                        <tr>
                            <th style="width:52px;">#</th>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Phone Number</th>
                            <th>Enrollment Date</th>
                            <th>Payment Status</th>
                        </tr>
                    </thead>
                    <tbody id="students_tbody">
                        <tr>
                            <td colspan="6" style="text-align:center; padding:2rem; color:#6b7280;">
                                Loading students...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <!-- footer (kept local & consistent with other views) -->
    <footer class="relative bg-blueGray-200 pt-8 pb-6">
        <div class="container mx-auto px-4">
            <div class="flex flex-wrap text-left lg:text-left">
                <div class="w-full lg:w-6/12 px-4">
                    <h4 class="text-3xl font-semibold text-blueGray-700">Liên hệ với chúng tôi!</h4>
                    <h5 class="text-lg mt-0 mb-2 text-blueGray-600">
                        Tìm kiếm chúng tôi trên bất kỳ mạng xã hội nào và gửi cho chúng tôi một tin nhắn! Chúng tôi sẽ trả
                        lời bạn ngay khi có thể.
                    </h5>
                    <div class="mt-6 lg:mb-0 mb-6">
                        <button class="bg-white text-lightBlue-400 shadow-lg font-normal h-10 w-10 rounded-full mr-2" type="button">
                            <i class="fab fa-twitter"></i></button>
                        <button class="bg-white text-lightBlue-600 shadow-lg font-normal h-10 w-10 rounded-full mr-2" type="button">
                            <i class="fab fa-facebook-square"></i></button>
                        <button class="bg-white text-pink-400 shadow-lg font-normal h-10 w-10 rounded-full mr-2" type="button">
                            <i class="fab fa-dribbble"></i></button>
                        <button class="bg-white text-blueGray-800 shadow-lg font-normal h-10 w-10 rounded-full mr-2" type="button">
                            <i class="fab fa-github"></i>
                        </button>
                    </div>
                </div>
                <div class="w-full lg:w-6/12 px-4">
                    <div class="flex flex-wrap items-top mb-6">
                        <div class="w-full lg:w-4/12 px-4 ml-auto">
                            <span class="block uppercase text-blueGray-500 text-sm font-semibold mb-2">Bạn Đang Tìm Kiếm</span>
                            <ul class="list-unstyled">
                                <li><a class="text-blueGray-600 hover:text-blueGray-800 font-semibold block pb-2 text-sm" href="">Liên Hệ</a></li>
                                <li><a class="text-blueGray-600 hover:text-blueGray-800 font-semibold block pb-2 text-sm" href="">Thông Tin Mới</a></li>
                                <li><a class="text-blueGray-600 hover:text-blueGray-800 font-semibold block pb-2 text-sm" href="">Tuyển Dụng</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
            <hr class="my-6 border-blueGray-300">
            <div class="flex flex-wrap items-center md:justify-between justify-center">
                <div class="w-full md:w-4/12 px-4 mx-auto text-center">
                    <div class="text-sm text-blueGray-500 font-semibold py-1">
                        Copyright © <span id="get-current-year">2025</span> <a href="https://www.facebook.com/ttgdvpttnht"
                            class="text-blueGray-500 hover:text-gray-800" target="_blank"> Talent Education</a>. Made by
                        <a href="https://github.com/Rin-0808" class="text-blueGray-500 hover:text-blueGray-800">Rin</a>.
                    </div>
                </div>
            </div>
        </div>
    </footer>
<script src="/js/auth-jwt.js"></script>
<script src="/js/script.js"></script>
<script src="/js/main.js"></script>
    <script>
        let classId = null;
        let classInfo = null;
        let students = [];

        // Extract classId from URL
        classId = window.location.pathname.split('/')[2];

        async function loadStudents() {
            try {
                const response = await AuthJWT.apiCall(`/api/classes/${classId}/students`, { method: 'GET' });
                const data = await response.json();

                if (response.ok) {
                    classInfo = data.classInfo;
                    students = data.students || [];
                    renderStudents();
                } else {
                    showError(data.error || 'Failed to load students');
                }
            } catch (error) {
                console.error('Error loading students:', error);
                showError('An error occurred while loading students');
            }
        }

        function renderStudents() {
            // Update class info
            document.getElementById('class_title').textContent = `Students in ${classInfo.class_name}`;
            document.getElementById('class_info').innerHTML = `Course: ${classInfo.course_name} &nbsp;|&nbsp; Teacher: ${classInfo.teacher_name}`;

            // Populate table
            const tbody = document.getElementById('students_tbody');
            tbody.innerHTML = '';

            if (students.length === 0) {
                tbody.innerHTML = '<tr><td colspan="6" style="text-align:center; padding:2rem; color:#6b7280;">There are no students enrolled in this class yet.</td></tr>';
                return;
            }

            students.forEach((student, index) => {
                const row = document.createElement('tr');
                const paymentBadge = student.payment_status 
                    ? `<span class="badge-paid">Paid</span>${student.payment_date ? `<div style="font-size:.82rem; color:#6b7280; margin-top:4px;">${new Date(student.payment_date).toLocaleDateString()}</div>` : ''}`
                    : '<span class="badge-unpaid">Unpaid</span>';
                
                row.innerHTML = `
                    <td style="font-weight:600;">${index + 1}</td>
                    <td>${student.full_name}</td>
                    <td>${student.email}</td>
                    <td>${student.phone_number}</td>
                    <td>${new Date(student.enrollment_date).toLocaleDateString()}</td>
                    <td>${paymentBadge}</td>
                `;
                tbody.appendChild(row);
            });
        }

        function showError(message) {
            const tbody = document.getElementById('students_tbody');
            tbody.innerHTML = `<tr><td colspan="6" style="text-align:center; padding:2rem; color:#ef4444;">${message}</td></tr>`;
        }

        document.addEventListener('DOMContentLoaded', loadStudents);
        document.getElementById('get-current-year').textContent = new Date().getFullYear();
    </script>
</body>

</html>