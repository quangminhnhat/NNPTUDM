    <script src="/js/script.js"></script>
    <script src="/js/main.js"></script>
    <script>
        const userId = window.location.pathname.split('/')[2];
        
        async function loadUserData() {
            try {
                const response = await AuthJWT.apiCall(`/api/users/${userId}/edit`, { method: 'GET' });
                if (!response.ok) throw new Error('Failed to load user data');
                const data = await response.json();
                const editUser = data.editUser;
                const user = data.user;
                
                // Set profile picture
                const profilePic = editUser.profile_pic ? '/' + editUser.profile_pic.replace(/\\/g, '/') : '/uploads/profile_pic/default_profile_pic.png';
                document.getElementById('currentProfilePic').src = profilePic;
                
                // Fill form fields
                document.getElementById('usernameInput').value = editUser.username;
                document.getElementById('roleSelect').value = editUser.role;
                document.getElementById('fullNameInput').value = editUser.full_name || '';
                document.getElementById('emailInput').value = editUser.email || '';
                document.getElementById('phoneNumberInput').value = editUser.phone_number || '';
                document.getElementById('addressInput').value = editUser.address || '';
                document.getElementById('dateOfBirthInput').value = editUser.date_of_birth || '';
                
                // Show salary field if teacher
                if (editUser.role === 'teacher') {
                    document.getElementById('salarySection').style.display = 'block';
                    document.getElementById('salaryInput').value = editUser.salary || 0;
                }
                
                // Set role select restrictions
                const roleSelect = document.getElementById('roleSelect');
                if (user.role !== 'admin' && user.id === editUser.id) {
                    roleSelect.disabled = true;
                    roleSelect.style.backgroundColor = '#e5e7eb';
                    roleSelect.style.cursor = 'not-allowed';
                }
                
                // Set back button destination
                const backLink = document.getElementById('backLink');
                if (user.role === 'admin' && user.id !== editUser.id) {
                    backLink.href = '/users';
                    backLink.innerHTML = '<i class="fas fa-arrow-left"></i> Back to Users';
                } else {
                    backLink.href = '/profile';
                    backLink.innerHTML = '<i class="fas fa-user"></i> View Profile';
                }
            } catch (error) {
                console.error('Error loading user data:', error);
                showError('Failed to load user data');
            }
        }
        
        function showError(message) {
            const errorDiv = document.getElementById('errorMessage');
            errorDiv.innerHTML = `<p class="font-bold">Error</p><p>${message}</p>`;
            errorDiv.style.display = 'block';
        }
        
        function showSuccess(message) {
            const successDiv = document.getElementById('successMessage');
            successDiv.innerHTML = `<p class="font-bold">Success</p><p>${message}</p>`;
            successDiv.style.display = 'block';
        }
        
        document.getElementById('editForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            try {
                const formData = new FormData(this);
                
                const response = await AuthJWT.apiCall(`/api/users/${userId}`, {
                    method: 'POST',
                    body: formData
                });
                
                if (!response.ok) {
                    const error = await response.json();
                    showError(error.error || 'Failed to update user');
                    return;
                }
                
                const result = await response.json();
                showSuccess('User updated successfully');
                setTimeout(() => {
                    window.location.href = result.redirect || '/profile';
                }, 1500);
            } catch (error) {
                console.error('Error updating user:', error);
                showError('Error updating user');
            }
        });
        
        document.getElementById('roleSelect').addEventListener('change', function() {
            const salarySection = document.getElementById('salarySection');
            if (this.value === 'teacher') {
                salarySection.style.display = 'block';
            } else {
                salarySection.style.display = 'none';
            }
        });
        
        document.addEventListener('DOMContentLoaded', loadUserData);
    </script>