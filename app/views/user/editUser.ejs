    <style>
    .modern-container {
        max-width: 1200px;
        margin: 48px auto 0 auto;
        padding: 2.5rem 2rem 2rem 2rem;
        background: #fff;
        border-radius: 18px;
        box-shadow: 0 4px 24px rgba(44, 62, 80, 0.10);
        border: 1px solid #e3e6ed;
        animation: fadeIn 0.5s;
    }
    .modern-title {
        font-size: 2rem;
        font-weight: 700;
        color: #2375D8;
        text-align: center;
        margin-bottom: 2rem;
        letter-spacing: 1px;
    }
    .modern-section {
        margin-bottom: 2rem;
        padding: 1.5rem;
        background: #f7fafc;
        border-radius: 10px;
    }
    .modern-section-title {
        font-size: 1.25rem;
        color: #4a5568;
        margin-bottom: 1rem;
        font-weight: 600;
    }
    .modern-info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1rem;
    }
    .modern-info-item {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }
    .modern-info-label {
        font-size: 0.875rem;
        color: #718096;
        font-weight: 500;
    }
    .modern-info-value {
        font-size: 1rem;
        color: #2d3748;
        font-weight: 600;
    }
    .modern-btn-primary {
        background: linear-gradient(90deg, #2375D8 0%, #0c9083 100%);
        color: #fff;
        font-weight: 700;
        font-size: 1.1rem;
        padding: 0.7rem 1.5rem;
        border: none;
        border-radius: 10px;
        box-shadow: 0 4px 16px rgba(36, 117, 216, 0.10);
        transition: background 0.2s, transform 0.15s;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        text-decoration: none;
    }
    .modern-btn-primary:hover {
        background: linear-gradient(90deg, #0c9083 0%, #2375D8 100%);
        transform: translateY(-2px) scale(1.03);
        box-shadow: 0 8px 24px rgba(36, 117, 216, 0.18);
    }
    .modern-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(18px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<main>
    <div class="modern-container">
        <div class="modern-header">
            <div class="modern-title">Edit User</div>
            <a href="/" class="modern-btn-primary" id="backBtn" style="font-size:1rem;padding:0.5rem 1.2rem; display:none;">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>

        <div id="errorMessage" style="display:none;" class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 mb-6"></div>
        <div id="successMessage" style="display:none;" class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 mb-6"></div>

        <form id="editForm" enctype="multipart/form-data" class="space-y-6">
            <div class="modern-section">
                <div class="modern-section-title">Profile Picture</div>
                <div class="flex items-center space-x-6">
                    <img 
                        id="currentProfilePic"
                        alt="Current Profile Picture" 
                        class="rounded-full h-24 w-24 object-cover border-2 border-gray-300">
                    <div>
                        <label for="profile_pic" class="modern-info-label">Change Picture</label>
                        <input type="file" name="profile_pic" id="profile_pic" class="mt-1 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100">
                    </div>
                </div>
            </div>
            <div class="modern-section">
                <div class="modern-section-title">Account Information</div>
                <div class="modern-info-grid">
                    <div class="modern-info-item">
                        <label class="modern-info-label">Username</label>
                        <input type="text" name="username" id="usernameInput" required
                            class="border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 modern-info-value">
                    </div>
                    <div class="modern-info-item">
                        <label class="modern-info-label">Role</label>
                        <select name="role" id="roleSelect" class="border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 modern-info-value">
                            <option value="student">Student</option>
                            <option value="teacher">Teacher</option>
                            <option value="admin">Admin</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modern-section">
                <div class="modern-section-title">Personal Information</div>
                <div class="modern-info-grid">
                    <div class="modern-info-item">
                        <label class="modern-info-label">Full Name</label>
                        <input type="text" name="full_name" id="fullNameInput" required
                            class="border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 modern-info-value">
                    </div>
                    <div class="modern-info-item">
                        <label class="modern-info-label">Email</label>
                        <input type="email" name="email" id="emailInput" required
                            class="border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 modern-info-value">
                    </div>
                    <div class="modern-info-item">
                        <label class="modern-info-label">Phone Number</label>
                        <input type="text" name="phone_number" id="phoneNumberInput" required
                            class="border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 modern-info-value">
                    </div>
                    <div class="modern-info-item">
                        <label class="modern-info-label">Address</label>
                        <input type="text" name="address" id="addressInput"
                            class="border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 modern-info-value">
                    </div>
                    <div class="modern-info-item">
                        <label class="modern-info-label">Date of Birth</label>
                        <input type="date" name="date_of_birth" id="dateOfBirthInput"
                            class="border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 modern-info-value">
                    </div>
                </div>
            </div>
            <div id="salarySection" style="display:none;" class="modern-section">
                <div class="modern-section-title">Teacher Information</div>
                <div class="modern-info-grid">
                    <div class="modern-info-item">
                        <label class="modern-info-label">Salary</label>
                        <input type="number" name="salary" id="salaryInput" step="0.01"
                            class="border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 modern-info-value">
                    </div>
                </div>
            </div>
            <div class="flex justify-between items-center mt-6">
                <a href="/" id="backLink" class="modern-btn-primary" style="background:#f7fafc;color:#2375D8;border:1px solid #2375D8;box-shadow:none;">
                    <i class="fas fa-arrow-left"></i> Back
                </a>
                <button type="submit" class="modern-btn-primary">
                    <i class="fas fa-save"></i> Save Changes
                </button>
            </div>
        </form>
    </div>
</main>

