<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Available Courses</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/mobile.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://demos.creative-tim.com/notus-js/assets/styles/tailwind.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet"
        href="https://demos.creative-tim.com/notus-js/assets/vendor/@fortawesome/fontawesome-free/css/all.min.css">
    <script src="/js/auth-jwt.js"></script>
        <style>
        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
        }
        body {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        main, .modern-container {
            flex: 1 0 auto;
        }
        footer {
            flex-shrink: 0;
        }
        .modern-container {
            max-width: 1200px;
            margin: 48px auto 0 auto;
            padding: 2.5rem 2rem 2rem 2rem;
            background: #fff;
            border-radius: 18px;
            box-shadow: 0 4px 24px rgba(44,62,80,0.10);
            border: 1px solid #e3e6ed;
            animation: fadeIn 0.5s;
        }
        .modern-title {
            font-size: 2rem;
            font-weight: 700;
            color: #2375D8;
            text-align: center;
            margin-bottom: 2rem;
            letter-spacing: 1px;
        }
        .modern-btn-primary {
            background: linear-gradient(90deg, #2375D8 0%, #0c9083 100%);
            color: #fff;
            font-weight: 700;
            font-size: 1.1rem;
            padding: 0.7rem 1.5rem;
            border: none;
            border-radius: 10px;
            box-shadow: 0 4px 16px rgba(36,117,216,0.10);
            transition: background 0.2s, transform 0.15s;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 0.7rem;
            text-decoration: none;
        }
        .modern-btn-primary:hover {
            background: linear-gradient(90deg, #0c9083 0%, #2375D8 100%);
            transform: translateY(-2px) scale(1.03);
            box-shadow: 0 8px 24px rgba(36,117,216,0.18);
        }
        .modern-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 1.5rem;
            background: #f9fafb;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(44,62,80,0.06);
        }
        .modern-table th, .modern-table td {
            padding: 1rem 1.2rem;
            text-align: left;
        }
        .modern-table th {
            background: #2375D8;
            color: #fff;
            font-weight: 600;
            font-size: 1rem;
            border-bottom: 2px solid #e3e6ed;
            text-align: center;
        }
        .modern-table tbody tr {
            background: #fff;
            transition: background 0.2s;
        }
        .modern-table tbody tr:hover {
            background: #e6f0fa;
        }
        .modern-table td {
            border-bottom: 1px solid #e3e6ed;
            font-size: 1rem;
            color: #374151;
            vertical-align: middle;
            text-align: center;
        }
        .modern-table .actions form button {
            color: #2375D8;
            font-size: 1.1rem;
            transition: color 0.2s;
            background: none;
            border: none;
            cursor: pointer;
            padding: 0 0.3rem;
        }
        .modern-table .actions form button:hover {
            color: #0c9083;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(18px);}
            to { opacity: 1; transform: translateY(0);}
        }
        .modern-search-sort {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            margin-bottom: 2rem;
        }
        @media (min-width: 768px) {
            .modern-search-sort {
                flex-direction: row;
                justify-content: space-between;
                align-items: center;
            }
        }
    </style>
</head>

<body>
  <%- include('../shared/header.ejs') %>
 
<% if (messages.error) { %>
<div id="loginPopup" class="fixed inset-0 flex items-center justify-center z-50">
  <div class="fixed inset-0 bg-black opacity-50"></div>
  <div class="bg-white rounded-lg p-8 relative z-10">
    <div class="flex flex-col items-center">
      <div class="text-xl font-bold text-red-600 mb-4">
        <i class="fas fa-exclamation-circle mr-2"></i>
        Authentication Required
      </div>
      <p class="text-gray-700 mb-4"><%= messages.error %></p>
      <button onclick="closePopup()" class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded">
        OK
      </button>
    </div>
  </div>
</div>

<script>
  function closePopup() {
    const popup = document.getElementById('loginPopup');
    if (popup) {
      popup.classList.add('fade-out');
      setTimeout(() => {
        popup.remove();
      }, 300);
    }
  }

  // Auto close after 3 seconds
  setTimeout(closePopup, 3000);
</script>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
    }

    to {
      opacity: 1;
    }
  }

  @keyframes fadeOut {
    from {
      opacity: 1;
    }

    to {
      opacity: 0;
    }
  }

  #loginPopup {
    animation: fadeIn 0.3s ease-in;
  }

  #loginPopup.fade-out {
    animation: fadeOut 0.3s ease-out;
  }
</style>
<% } %>

<main>
  <div class="modern-container">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
      <div class="modern-title">
        <i class="fas fa-book-reader"></i> Available Courses
      </div>
      <!-- No add button for students -->
    </div>
    <div class="modern-search-sort">
      <div class="relative w-full sm:w-64">
        <input type="text" id="searchInput" placeholder="Search courses..."
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
        <i class="fas fa-search absolute right-3 top-3 text-gray-400"></i>
      </div>
      <select id="sortSelect"
        class="w-full sm:w-48 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white">
        <option value="name">Sort by Name</option>
        <option value="date">Sort by Start Date</option>
        <option value="price">Sort by Price</option>
      </select>
    </div>
    <div class="overflow-x-auto">
      <table class="modern-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Start Date</th>
            <th>Description</th>
            <th>Teacher</th>
            <th>Schedule</th>
            <th>Time</th>
            <th>Enrolled</th>
            <th>Tuition</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody id="courseTableBody">
          <tr>
            <td colspan="9" style="text-align:center; color:#888; padding:2rem;">Loading courses...</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</main>

<script src="/js/script.js"></script>
<script src="/js/main.js"></script>
<script>
  let allCourses = [];
  
  async function loadAvailableCourses() {
    try {
      const response = await AuthJWT.apiCall('/api/available-courses', {
        method: 'GET',
        headers: { 'Content-Type': 'application/json' }
      });
      
      if (!response.ok) throw new Error('Failed to load courses');
      
      const data = await response.json();
      allCourses = data.courses || [];
      renderCourses(allCourses);
    } catch (error) {
      console.error('Error loading courses:', error);
      const tbody = document.getElementById('courseTableBody');
      tbody.innerHTML = `<tr><td colspan="9" style="text-align:center; color:#ef4444; padding:2rem;">Error loading courses: ${error.message}</td></tr>`;
    }
  }
  
  function renderCourses(courses) {
    const tbody = document.getElementById('courseTableBody');
    
    if (courses.length === 0) {
      tbody.innerHTML = `
        <tr>
          <td colspan="9" style="height:260px; padding:0;">
            <div style="height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;">
              <i class="fas fa-book-open text-4xl mb-3"></i>
              <div>No courses available.</div>
            </div>
          </td>
        </tr>
      `;
      return;
    }
    
    tbody.innerHTML = courses.map(course => `
      <tr class="course-row" data-name="${course.course_name}" data-date="${new Date(course.start_date).getTime()}" data-price="${course.tuition_fee || 0}">
        <td>${course.course_name}</td>
        <td>${new Date(course.start_date).toLocaleDateString()}</td>
        <td style="max-width:200px;white-space:normal;">${course.description || ''}</td>
        <td>${course.teacher_name}</td>
        <td>${course.weekly_schedule || 'N/A'}</td>
        <td>${course.start_time || ''} - ${course.end_time || ''}</td>
        <td>${course.enrolled_count || 0} students</td>
        <td><span class="font-semibold text-green-600">${(course.tuition_fee || 0).toLocaleString()} VND</span></td>
        <td class="actions">
          <button onclick="enrollCourse(${course.class_id})" 
            class="modern-btn-primary" 
            style="padding: 0.5rem 1rem; font-size: 0.9rem;">
            <i class="fas fa-user-plus"></i>
          </button>
        </td>
      </tr>
    `).join('');
  }
  
  async function enrollCourse(classId) {
    if (!confirm('Are you sure you want to enroll in this course?')) return;
    
    try {
      const response = await AuthJWT.apiCall('/api/enroll-course', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ class_id: classId })
      });
      
      if (!response.ok) {
        const error = await response.json();
        throw new Error(error.error || 'Failed to enroll');
      }
      
      const data = await response.json();
      alert('Enrolled successfully!');
      if (data.redirect) {
        window.location.href = data.redirect;
      } else {
        loadAvailableCourses();
      }
    } catch (error) {
      console.error('Enrollment error:', error);
      alert('Error: ' + error.message);
    }
  }
  
  // Search functionality
  document.getElementById('searchInput').addEventListener('input', function (e) {
    const searchText = e.target.value.toLowerCase();
    const rows = document.querySelectorAll('.course-row');
    rows.forEach(row => {
      const text = row.textContent.toLowerCase();
      row.style.display = text.includes(searchText) ? '' : 'none';
    });
  });

  // Sorting functionality
  document.getElementById('sortSelect').addEventListener('change', function (e) {
    const sortedCourses = [...allCourses];
    
    if (e.target.value === 'name') {
      sortedCourses.sort((a, b) => a.course_name.localeCompare(b.course_name));
    } else if (e.target.value === 'date') {
      sortedCourses.sort((a, b) => new Date(a.start_date) - new Date(b.start_date));
    } else if (e.target.value === 'price') {
      sortedCourses.sort((a, b) => (a.tuition_fee || 0) - (b.tuition_fee || 0));
    }
    
    renderCourses(sortedCourses);
  });
  
  document.addEventListener('DOMContentLoaded', loadAvailableCourses);
</script>

