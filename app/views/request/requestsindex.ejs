<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Requests</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/mobile.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://demos.creative-tim.com/notus-js/assets/styles/tailwind.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet"
        href="https://demos.creative-tim.com/notus-js/assets/vendor/@fortawesome/fontawesome-free/css/all.min.css">
    
    <script src="/js/auth-jwt.js"></script>
   <style>
        .modern-container {
            max-width: 1200px;
            margin: 48px auto;
            padding: 2.5rem 2rem;
            background: #fff;
            border-radius: 18px;
            box-shadow: 0 4px 24px rgba(44,62,80,0.10);
            border: 1px solid #e3e6ed;
            animation: fadeIn 0.45s ease;
        }
        .modern-title {
            font-size: 1.8rem;
            font-weight: 700;
            color: #2375D8;
            display:flex;
            align-items:center;
            gap:0.6rem;
        }
        .modern-btn-primary {
            background: linear-gradient(90deg, #2375D8 0%, #0c9083 100%);
            color: #fff;
            font-weight: 700;
            font-size: 1rem;
            padding: 0.6rem 1rem;
            border: none;
            border-radius: 10px;
            box-shadow: 0 4px 16px rgba(36,117,216,0.10);
            transition: background 0.2s, transform 0.12s;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 0.6rem;
            text-decoration: none;
        }
        .modern-btn-primary:hover { transform: translateY(-2px); }

        .modern-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 1.5rem;
            background: #fff;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(44,62,80,0.06);
        }
        .modern-table th, .modern-table td { padding: 0.9rem 1rem; text-align: left; }
        .modern-table th { background: #2375D8; color: #fff; font-weight: 600; }
        .modern-table tbody tr:hover { background: #f6fafc; }
        .modern-table td { border-bottom: 1px solid #eef2f6; color: #374151; }
        
        .status-badge {
            padding: 0.25rem 0.6rem;
            border-radius: 999px;
            font-weight: 600;
            font-size: 0.85rem;
        }
        .status-badge.pending { background-color: #FEF3C7; color: #92400E; }
        .status-badge.approved { background-color: #D1FAE5; color: #065F46; }
        .status-badge.rejected { background-color: #FEE2E2; color: #991B1B; }

        .actions { display: flex; gap: 0.5rem; }
        .action-btn {
            padding: 0.3rem 0.7rem;
            border-radius: 6px;
            border: none;
            color: white;
            cursor: pointer;
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 600;
        }
        .approve-btn { background-color: #059669; }
        .reject-btn { background-color: #DC2626; }
        .edit-btn { background-color: #2563EB; }
        .icon-btn { background:none; border:none; cursor:pointer; padding:0.4rem; font-size:1.1rem; }
        .delete-btn { color: #ef4444; }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(18px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>

<body>
    <%- include('../shared/header.ejs') %>

    <main>
        <div class="modern-container">
            <div style="display:flex; justify-content:space-between; align-items:center;">
                <h2 class="modern-title"><i class="fas fa-inbox"></i> Requests</h2>
                <a href="/requests/new" class="modern-btn-primary" id="createBtn" style="display:none;"><i class="fas fa-plus"></i> Create Request</a>
            </div>

            <div style="overflow-x: auto;">
                <table class="modern-table">
                    <thead>
                        <tr>
                            <th>Type</th>
                            <th>User</th>
                            <th>Description</th>
                            <th>Class</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="requestsTableBody">
                        <tr><td colspan="7" style="text-align: center; padding: 2rem; color: #6b7280;">Loading requests...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <script>
    let currentUserRole = '';
    let currentUserId = '';
    
    async function loadRequests() {
      try {
        // Get user info from token - use authToken not jwtToken
        const token = localStorage.getItem('authToken');
        if (!token) {
          throw new Error('No authentication token found. Please log in.');
        }
        
        try {
          const decoded = JSON.parse(atob(token.split('.')[1]));
          currentUserRole = decoded.role;
          currentUserId = decoded.id;
          console.log('User info:', { currentUserRole, currentUserId });
        } catch (tokenError) {
          console.error('Error parsing JWT token:', tokenError);
          throw new Error('Invalid token format');
        }
        
        // Show create button if not admin
        if (currentUserRole !== 'admin') {
          document.getElementById('createBtn').style.display = 'inline-flex';
        }
        
        console.log('Fetching requests from /api/requests');
        const response = await AuthJWT.apiCall('/api/requests', { method: 'GET' });
        
        console.log('Response status:', response.status);
        
        if (!response.ok) {
          throw new Error(`HTTP Error: ${response.status}`);
        }
        
        const data = await response.json();
        console.log('Response data:', data);
        
        const requests = data.requests || [];
        console.log('Requests count:', requests.length);
        
        const tbody = document.getElementById('requestsTableBody');
        
        if (!requests || requests.length === 0) {
          tbody.innerHTML = '<tr><td colspan="7" style="text-align: center; padding: 2rem; color: #6b7280;">No requests found.</td></tr>';
          return;
        }
        
        tbody.innerHTML = requests.map(request => `
          <tr>
            <td>${request.type_name}</td>
            <td>${request.full_name} (${request.username})</td>
            <td>${request.description}</td>
            <td>${request.class_name || 'N/A'}</td>
            <td><span class="status-badge ${request.status}">${request.status}</span></td>
            <td>${new Date(request.created_at).toLocaleDateString()}</td>
            <td class="actions">
              ${(currentUserRole === 'admin' || (currentUserRole === 'teacher' && request.role === 'student')) ? `
                ${request.status === 'pending' ? `
                  <button onclick="toggleStatus(${request.request_id})" class="action-btn approve-btn">Approve</button>
                  <button onclick="toggleStatus(${request.request_id})" class="action-btn reject-btn">Reject</button>
                ` : request.status === 'approved' ? `
                  <button onclick="toggleStatus(${request.request_id})" class="action-btn reject-btn">Reject</button>
                ` : `
                  <button onclick="toggleStatus(${request.request_id})" class="action-btn approve-btn">Approve</button>
                `}
              ` : ''}
              
              ${request.status === 'pending' && request.user_id === currentUserId ? `
                <a href="/requests/${request.request_id}/edit" class="icon-btn" title="Edit" style="color:#2563EB;"><i class="fas fa-edit"></i></a>
                <button onclick="deleteRequest(${request.request_id})" class="icon-btn delete-btn" title="Delete"><i class="fas fa-trash"></i></button>
              ` : ''}
            </td>
          </tr>
        `).join('');
      } catch (error) {
        console.error('Error loading requests:', error);
        document.getElementById('requestsTableBody').innerHTML = 
          `<tr><td colspan="7" style="text-align: center; padding: 2rem; color: #ef4444;">Error loading requests: ${error.message}</td></tr>`;
      }
    }
    
    async function deleteRequest(requestId) {
      if (confirm('Are you sure you want to delete this request?')) {
        try {
          const response = await AuthJWT.apiCall(`/api/requestDelete/${requestId}`, { method: 'DELETE' });
          if (response.ok) {
            loadRequests();
          } else {
            alert((await response.json()).error || 'Failed to delete request');
          }
        } catch (error) {
          alert('Error deleting request');
        }
      }
    }
    
    async function toggleStatus(requestId) {
      if (confirm('Are you sure you want to change this request\'s status?')) {
        try {
          const response = await AuthJWT.apiCall(`/api/requestToggleStatus/${requestId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' }
          });
          if (response.ok) {
            loadRequests();
          } else {
            alert((await response.json()).error || 'Failed to update status');
          }
        } catch (error) {
          alert('Error updating request status');
        }
      }
    }
    
    document.addEventListener('DOMContentLoaded', loadRequests);
    </script>

    <%- include('../shared/footer.ejs') %>
</body>

</html>