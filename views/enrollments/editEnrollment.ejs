   <style>
    html, body {
        height: 100%;
        min-height: 100%;
        margin: 0;
        padding: 0;
    }
    body {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }
    main {
        flex: 1 0 auto;
    }
    footer {
        flex-shrink: 0;
        width: 100%;
    }
    .modern-form-container {
        max-width: 1200px;
        margin: 48px auto 0 auto;
        padding: 2.5rem 2rem 2rem 2rem;
        background: #fff;
        border-radius: 18px;
        box-shadow: 0 4px 24px rgba(44,62,80,0.10);
        border: 1px solid #e3e6ed;
        animation: fadeIn 0.5s;
    }
    .modern-form-title {
        font-size: 2rem;
        font-weight: 700;
        color: #2375D8;
        text-align: center;
        margin-bottom: 2rem;
        letter-spacing: 1px;
    }
    .modern-form-group {
        margin-bottom: 1.5rem;
    }
    .modern-form-group label {
        display: block;
        font-weight: 600;
        color: #374151;
        margin-bottom: 0.5rem;
        letter-spacing: 0.5px;
    }
    .modern-form-control, .modern-form-control:focus {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1.5px solid #e5e7eb;
        border-radius: 8px;
        font-size: 1rem;
        background: #f9fafb;
        transition: border-color 0.2s, box-shadow 0.2s;
        outline: none;
        color: #22223b;
    }
    .modern-form-control:focus {
        border-color: #2375D8;
        box-shadow: 0 0 0 2px #2375d830;
        background: #fff;
    }
    .modern-btn-primary {
        width: 100%;
        background: linear-gradient(90deg, #2375D8 0%, #0c9083 100%);
        color: #fff;
        font-weight: 700;
        font-size: 1.1rem;
        padding: 0.85rem 0;
        border: none;
        border-radius: 10px;
        box-shadow: 0 4px 16px rgba(36,117,216,0.10);
        transition: background 0.2s, transform 0.15s;
        cursor: pointer;
        margin-top: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.7rem;
    }
    .modern-btn-primary:hover {
        background: linear-gradient(90deg, #0c9083 0%, #2375D8 100%);
        transform: translateY(-2px) scale(1.03);
        box-shadow: 0 8px 24px rgba(36,117,216,0.18);
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px);}
        to { opacity: 1; transform: translateY(0);}
    }
</style>
</head>


<%- include('../shared/header.ejs') %>
 
 



<body>
    <main>
  <form id="editEnrollmentForm" class="modern-form-container" autocomplete="off">
    <legend class="modern-form-title">
      <i class="fas fa-user-edit mr-2"></i>
      Edit Enrollment
    </legend>
    <div id="messageContainer"></div>
    <div class="modern-form-group">
      <label for="student_id"><i class="fas fa-user-graduate mr-2"></i>Student</label>
      <input type="text" id="student_name" name="student_name" class="modern-form-control" disabled>
      <input type="hidden" name="student_id" id="student_id_hidden">
    </div>
    <div class="modern-form-group">
      <label for="class_id"><i class="fas fa-chalkboard-teacher mr-2"></i>Class</label>
      <select id="class_id" name="class_id" class="modern-form-control" required>
        <option value="">Loading classes...</option>
      </select>
    </div>
    <div class="modern-form-group">
      <label for="enrollment_date"><i class="fas fa-calendar-alt mr-2"></i>Enrollment Date</label>
      <input type="date" id="enrollment_date" name="enrollment_date" class="modern-form-control" readonly>
    </div>
    <button type="submit" class="modern-btn-primary">
      <i class="fas fa-save"></i>
      Save Changes
    </button>
    <a href="/enrollments" class="modern-btn-primary" style="background: #e5e7eb; color: #2375D8; margin-top: 10px;">
      <i class="fas fa-arrow-left"></i> Back
    </a>
  </form>

  <script>
    // Extract enrollment ID from URL
    const enrollmentId = window.location.pathname.split('/').pop();

    // Load enrollment data and populate form
    async function loadEnrollmentData() {
      try {
        const response = await fetch(`/api/enrollments/${enrollmentId}/edit`);
        if (!response.ok) throw new Error('Failed to load enrollment data');
        const data = await response.json();
        
        if (data.enrollment) {
          document.getElementById('student_name').value = data.enrollment.student_name || '';
          document.getElementById('student_id_hidden').value = data.enrollment.student_id || '';
          document.getElementById('enrollment_date').value = data.enrollment.enrollment_date ? 
            new Date(data.enrollment.enrollment_date).toISOString().split('T')[0] : '';
          
          // Set the current class selected
          const classSelect = document.getElementById('class_id');
          classSelect.value = data.enrollment.class_id || '';
        }
      } catch (error) {
        console.error('Error loading enrollment:', error);
        showMessage('Error loading enrollment data', 'error');
      }
    }

    // Load available classes
    async function loadClasses() {
      try {
        const response = await fetch('/api/enrollments/new');
        if (!response.ok) throw new Error('Failed to load classes');
        const data = await response.json();
        
        const classSelect = document.getElementById('class_id');
        classSelect.innerHTML = '<option value="">Select a class...</option>';
        
        if (data.classes && Array.isArray(data.classes)) {
          data.classes.forEach(cls => {
            const option = document.createElement('option');
            option.value = cls.id;
            option.textContent = cls.name;
            classSelect.appendChild(option);
          });
        }
      } catch (error) {
        console.error('Error loading classes:', error);
        showMessage('Error loading classes', 'error');
      }
    }

    // Show message
    function showMessage(message, type = 'success') {
      const container = document.getElementById('messageContainer');
      container.innerHTML = `
        <div class="p-3 rounded-lg ${type === 'success' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}">
          <i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'} mr-2"></i>
          ${message}
        </div>
      `;
      setTimeout(() => {
        container.innerHTML = '';
      }, 5000);
    }

    // Handle form submission
    document.getElementById('editEnrollmentForm').addEventListener('submit', async (e) => {
      e.preventDefault();

      const classId = document.getElementById('class_id').value;
      
      if (!classId) {
        showMessage('Please select a class', 'error');
        return;
      }

      try {
        const response = await fetch(`/api/enrollments/${enrollmentId}`, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            class_id: parseInt(classId)
          })
        });

        if (response.ok) {
          showMessage('Enrollment updated successfully');
          setTimeout(() => {
            window.location.href = '/enrollments';
          }, 1500);
        } else {
          const error = await response.json();
          showMessage(error.message || 'Error updating enrollment', 'error');
        }
      } catch (error) {
        console.error('Error updating enrollment:', error);
        showMessage('Error updating enrollment', 'error');
      }
    });

    // Initialize on page load
    document.addEventListener('DOMContentLoaded', () => {
      loadClasses();
      loadEnrollmentData();
    });
  </script>
</main>
