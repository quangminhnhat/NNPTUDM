<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Request</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/mobile.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://demos.creative-tim.com/notus-js/assets/styles/tailwind.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet"
        href="https://demos.creative-tim.com/notus-js/assets/vendor/@fortawesome/fontawesome-free/css/all.min.css">
    
    <script src="/js/auth-jwt.js"></script>
   <style>
        .modern-container {
            max-width: 1200px;
            margin: 48px auto;
            padding: 2.25rem 2rem;
            background: #fff;
            border-radius: 14px;
            box-shadow: 0 6px 30px rgba(44,62,80,0.08);
            border: 1px solid #e6e9ef;
            animation: fadeIn 0.4s ease;
        }
        .modern-title {
            font-size: 1.6rem;
            font-weight: 700;
            color: #2375D8;
            margin-bottom: 1.25rem;
            display:flex;
            align-items:center;
            gap:0.6rem;
        }
        .modern-form-group { margin-bottom: 1.1rem; }
        .modern-form-group label { display:block; margin-bottom:0.45rem; font-weight:600; color:#374151; }
        .modern-form-control {
            width:100%;
            padding:0.7rem;
            border:1px solid #e2e8f0;
            border-radius:8px;
            font-size:1rem;
        }
        .modern-btn-primary, .modern-btn-secondary {
            font-weight:700;
            padding:0.85rem 1rem;
            border:none;
            border-radius:10px;
            cursor:pointer;
            display:inline-flex;
            gap:0.6rem;
            align-items:center;
            justify-content:center;
            text-decoration: none;
        }
        .modern-btn-primary {
            background: linear-gradient(90deg, #2375D8 0%, #0c9083 100%);
            color: #fff;
        }
        .modern-btn-secondary {
            background:#f1f5f9;
            color:#475569;
        }
        @keyframes fadeIn { from { opacity:0; transform:translateY(10px);} to { opacity:1; transform:translateY(0);} }
    </style>
</head>

<body>
    <%- include('../shared/header.ejs') %>

<main>
    <div class="modern-container">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
            <div class="modern-title">
                <i class="fas fa-plus-circle"></i>
                <%= title %>
            </div>
            <div>
                <a href="/requests" class="modern-btn-secondary"><i class="fas fa-arrow-left"></i> Back</a>
            </div>
        </div>
        
        <form id="requestForm">
            <div class="modern-form-group">
                <label for="requestType">Request Type</label>
                <select name="requestType" id="requestType" class="modern-form-control" required>
                    <option value="">Select Request Type</option>
                </select>
            </div>

            <div class="modern-form-group">
                <label for="classId">Related Class (Optional)</label>
                <select name="classId" id="classId" class="modern-form-control">
                    <option value="">None</option>
                </select>
            </div>

            <div class="modern-form-group">
                <label for="details">Details</label>
                <textarea name="details" id="details" rows="5" class="modern-form-control" required></textarea>
            </div>
            
            <div style="display:flex; justify-content:flex-end; gap:1rem; margin-top:2rem;">
                <a href="/requests" class="modern-btn-secondary"><i class="fas fa-times"></i> Cancel</a>
                <button type="submit" class="modern-btn-primary"><i class="fas fa-paper-plane"></i> Submit Request</button>
            </div>
        </form>
    </div>
</main>

<script>
async function loadFormData() {
  try {
    const response = await fetch('/api/requests/new');
    if (!response.ok) throw new Error('Failed to load form data');
    const data = await response.json();
    
    const requestTypes = data.requestTypes || [];
    const classes = data.classes || [];
    
    // Populate request types
    const typeSelect = document.getElementById('requestType');
    typeSelect.innerHTML = '<option value="">Select Request Type</option>' +
      requestTypes.map(t => `<option value="${t.type_name}">${t.type_name}</option>`).join('');
    
    // Populate classes
    const classSelect = document.getElementById('classId');
    classSelect.innerHTML = '<option value="">None</option>' +
      classes.map(c => `<option value="${c.id}">${c.class_name}</option>`).join('');
  } catch (error) {
    console.error('Error loading form data:', error);
    alert('Error loading form data');
  }
}

document.getElementById('requestForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    try {
        const response = await fetch('/api/requestAdd', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                requestType: document.getElementById('requestType').value,
                details: document.getElementById('details').value,
                classId: document.getElementById('classId').value || null
            })
        });

        if (response.ok) {
            window.location.href = '/requests';
        } else {
            alert((await response.json()).error || 'Failed to submit request');
        }
    } catch (error) {
        alert('Error submitting request');
    }
});

document.addEventListener('DOMContentLoaded', loadFormData);
</script>

<%- include('../shared/footer.ejs') %>
</body>
</html>