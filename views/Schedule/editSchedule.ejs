<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trang Chủ</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/mobile.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://demos.creative-tim.com/notus-js/assets/styles/tailwind.css">
    <!-- link swiper-->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet"
        href="https://demos.creative-tim.com/notus-js/assets/vendor/@fortawesome/fontawesome-free/css/all.min.css">
    <script src="/js/auth-jwt.js"></script>
      </head>

<body>
   <%- include('../shared/header.ejs') %>
 
 



    <div class="container mx-auto px-4 py-8">
      <div class="max-w-2xl mx-auto bg-white rounded-lg shadow-md p-6">
        <h1 class="text-2xl font-bold mb-6">Edit Schedule</h1>

        <form id="scheduleForm" class="space-y-6">
          <div class="form-group">
            <label for="class_id" class="block text-sm font-medium text-gray-700">Class:</label>
            <select id="class_id" name="class_id" class="mt-1 block w-full rounded-md border-gray-300" required>
              <option value="">Loading classes...</option>
            </select>
          </div>

          <div class="form-group">
            <label for="schedule_date" class="block text-sm font-medium text-gray-700">Date:</label>
            <input type="date" 
                   id="schedule_date" 
                   name="schedule_date" 
                   class="mt-1 block w-full rounded-md border-gray-300" 
                   required>
          </div>

          <div class="form-group">
            <label for="day_of_week" class="block text-sm font-medium text-gray-700">Day of Week:</label>
            <select id="day_of_week" name="day_of_week" 
                    class="mt-1 block w-full rounded-md border-gray-300" 
                    style="pointer-events: none; background-color: #e9ecef;"
                    readonly
                    tabindex="-1"
                    required>
              <option value="Monday">Monday</option>
              <option value="Tuesday">Tuesday</option>
              <option value="Wednesday">Wednesday</option>
              <option value="Thursday">Thursday</option>
              <option value="Friday">Friday</option>
              <option value="Saturday">Saturday</option>
              <option value="Sunday">Sunday</option>
            </select>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="form-group">
              <label for="start_time" class="block text-sm font-medium text-gray-700">Start Time:</label>
              <input type="time" 
                     id="start_time" 
                     name="start_time" 
                     step="3600"
                     class="mt-1 block w-full rounded-md border-gray-300" 
                     required>
            </div>

            <div class="form-group">
              <label for="end_time" class="block text-sm font-medium text-gray-700">End Time:</label>
              <input type="time" 
                     id="end_time" 
                     name="end_time" 
                     step="3600"
                     class="mt-1 block w-full rounded-md border-gray-300" 
                     required>
            </div>
          </div>

          <div class="flex justify-end space-x-4">
            <a href="/schedules" class="px-4 py-2 bg-gray-300 text-gray-700 rounded hover:bg-gray-400">
              Cancel
            </a>
            <button type="submit" class="px-4 py-2 bg-blue-500 text-black rounded hover:bg-blue-600">
              Update Schedule
            </button>
            <button type="button" onclick="deleteSchedule()" class="px-4 py-2 bg-red-500 text-white rounded hover:bg-red-600">
              Delete
            </button>
          </div>
        </form>
      </div>

      <script>
        const scheduleId = window.location.pathname.split('/')[2];
        
        async function loadScheduleData() {
          try {
            const response = await fetch(`/api/schedules/${scheduleId}/edit`);
            if (!response.ok) throw new Error('Failed to load schedule');
            const data = await response.json();
            
            // Populate classes
            const classSelect = document.getElementById('class_id');
            classSelect.innerHTML = '';
            data.classes.forEach(cls => {
              const option = document.createElement('option');
              option.value = cls.id;
              option.textContent = `${cls.class_name} - ${cls.course_name} (${cls.teacher_name})`;
              option.dataset.courseStart = cls.start_date;
              option.dataset.courseEnd = cls.end_date;
              if (cls.id === data.schedule.class_id) {
                option.selected = true;
              }
              classSelect.appendChild(option);
            });
            
            // Fill in schedule data
            document.getElementById('schedule_date').value = data.schedule.formatted_schedule_date;
            document.getElementById('start_time').value = data.schedule.formatted_start_time;
            document.getElementById('end_time').value = data.schedule.formatted_end_time;
            document.getElementById('day_of_week').value = data.schedule.day_of_week;
            
            updateDateRestrictions();
          } catch (error) {
            console.error('Error loading schedule:', error);
            alert('Failed to load schedule');
          }
        }
        
        function updateDateRestrictions() {
          const classSelect = document.getElementById('class_id');
          const selectedOption = classSelect.options[classSelect.selectedIndex];
          const dateInput = document.getElementById('schedule_date');
          dateInput.min = selectedOption.dataset.courseStart;
          dateInput.max = selectedOption.dataset.courseEnd;
        }
        
        document.getElementById('scheduleForm').addEventListener('submit', async function(e) {
          e.preventDefault();
          
          try {
            const classSelect = document.getElementById('class_id');
            const selectedOption = classSelect.options[classSelect.selectedIndex];
            
            const scheduleDate = new Date(document.getElementById('schedule_date').value);
            const courseStart = new Date(selectedOption.dataset.courseStart);
            const courseEnd = new Date(selectedOption.dataset.courseEnd);
            
            if (scheduleDate < courseStart || scheduleDate > courseEnd) {
              alert('Schedule date must be within the course dates');
              return;
            }
            
            const startTime = document.getElementById('start_time').value;
            const endTime = document.getElementById('end_time').value;
            
            if (startTime >= endTime) {
              alert('End time must be after start time');
              return;
            }
            
            const formData = new FormData();
            formData.append('class_id', document.getElementById('class_id').value);
            formData.append('schedule_date', document.getElementById('schedule_date').value);
            formData.append('day_of_week', document.getElementById('day_of_week').value);
            formData.append('start_time', startTime);
            formData.append('end_time', endTime);
            
            const response = await fetch(`/api/schedules/${scheduleId}`, {
              method: 'POST',
              body: formData
            });
            
            if (response.ok) {
              alert('Schedule updated successfully');
              window.location.href = '/schedules';
            } else {
              const error = await response.json();
              alert(error.message || 'Failed to update schedule');
            }
          } catch (error) {
            console.error('Error updating schedule:', error);
            alert('Error updating schedule');
          }
        });
        
        async function deleteSchedule() {
          if (confirm('Are you sure you want to delete this schedule?')) {
            try {
              const response = await fetch(`/api/schedules/${scheduleId}`, { method: 'DELETE' });
              if (response.ok) {
                alert('Schedule deleted successfully');
                window.location.href = '/schedules';
              } else {
                alert('Failed to delete schedule');
              }
            } catch (error) {
              alert('Error deleting schedule');
            }
          }
        }
        
        document.getElementById('class_id').addEventListener('change', updateDateRestrictions);
        
        document.getElementById('schedule_date').addEventListener('change', function() {
          const dateValue = this.value;
          if (!dateValue) return;
          const parts = dateValue.split('-');
          const year = parseInt(parts[0], 10);
          const month = parseInt(parts[1], 10) - 1;
          const day = parseInt(parts[2], 10);
          const selectedDate = new Date(Date.UTC(year, month, day));
          const dayIndex = selectedDate.getUTCDay();
          const daysOfWeek = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
          document.getElementById('day_of_week').value = daysOfWeek[dayIndex];
        });
        
        document.addEventListener('DOMContentLoaded', loadScheduleData);
      </script>
    </div>

