<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Take Exam</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/mobile.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://demos.creative-tim.com/notus-js/assets/styles/tailwind.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet"
        href="https://demos.creative-tim.com/notus-js/assets/vendor/@fortawesome/fontawesome-free/css/all.min.css">
    <script src="/js/auth-jwt.js"></script>
    <style>
        main, .modern-container {
            flex: 1 0 auto;
        }
        footer {
            flex-shrink: 0;
        }
        .modern-container {
            max-width: 1200px;
            margin: 48px auto;
            padding: 2.5rem 2rem;
            background: #fff;
            border-radius: 18px;
            box-shadow: 0 4px 24px rgba(44,62,80,0.10);
            border: 1px solid #e3e6ed;
            animation: fadeIn 0.45s ease;
        }
        .exam-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            border-bottom: 1px solid #eef2f6;
            padding-bottom: 1rem;
        }
        .exam-title h2 {
            font-size: 1.8rem;
            font-weight: 700;
            color: #2375D8;
            margin: 0;
        }
        .exam-title p {
            color: #6b7280;
            margin: 0;
        }
        .timer-container h4 {
            font-size: 1.4rem;
            font-weight: 700;
            color: #ef4444;
            background: #fee2e2;
            padding: 0.5rem 1rem;
            border-radius: 10px;
        }
        .modern-question-card {
            background: #fff;
            border: 1px solid #e3e6ed;
            border-radius: 12px;
            margin-bottom: 1.5rem;
            box-shadow: 0 2px 8px rgba(44,62,80,0.06);
            overflow: hidden;
        }
        .modern-card-header {
            background: #f9fafb;
            padding: 0.9rem 1.25rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #e3e6ed;
        }
        .modern-card-header h5 {
            font-size: 1.1rem;
            font-weight: 600;
            color: #1f2937;
            margin: 0;
        }
        .points-badge {
            background: #2375D8;
            color: #fff;
            padding: 0.25rem 0.6rem;
            border-radius: 999px;
            font-size: 0.85rem;
            font-weight: 600;
        }
        .modern-card-body {
            padding: 1.25rem;
        }
        .question-text {
            font-size: 1rem;
            color: #374151;
            margin-bottom: 1.25rem;
        }
        .modern-form-check {
            margin-bottom: 0.75rem;
            display: flex;
            align-items: center;
        }
        .modern-form-check input[type="radio"] {
            width: 1.15em;
            height: 1.15em;
            margin-right: 0.5rem;
            accent-color: #2375D8;
        }
        .modern-form-check label {
            font-size: 1rem;
            color: #374151;
        }
        .modern-textarea {
            width: 100%;
            padding: 0.7rem;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            font-size: 1rem;
        }
        .modern-file-input {
            width: 100%;
            padding: 0.5rem;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
        }
        .modern-btn-primary {
            background: linear-gradient(90deg, #2375D8 0%, #0c9083 100%);
            color: #fff;
            font-weight: 700;
            font-size: 1.1rem;
            padding: 0.8rem 1.75rem;
            border: none;
            border-radius: 10px;
            box-shadow: 0 4px 16px rgba(36,117,216,0.10);
            transition: background 0.2s, transform 0.12s;
            cursor: pointer;
        }
        .modern-btn-primary:hover { transform: translateY(-2px); }

        .alert { padding: 0.8rem 1rem; border-radius: 8px; margin-bottom: 1.5rem; }
        .alert-warning { background: #fffbeb; color: #b45309; border: 1px solid #fef3c7; }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(18px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>

<body>
<%- include('../shared/header') %>

<main>
    <div class="modern-container" id="examContainer">
        <div class="exam-header">
            <div class="exam-title">
                <h2 id="examTitle">Loading...</h2>
                <p id="examCode">Exam Code: -</p>
            </div>
            <div class="timer-container">
                <h4>Time: <span id="timer"></span></h4>
            </div>
        </div>

        <div class="alert alert-warning" role="alert">
            Do not refresh or close the page. Your progress is automatically saved.
        </div>

        <form id="examForm" novalidate>
            <input type="hidden" id="attemptId">
            <div id="questionContainer">
                <div style="text-align:center; padding:2rem; color:#6b7280;">Loading questions...</div>
            </div>
            <div class="text-center mt-4 mb-5">
                <button type="submit" class="modern-btn-primary">Submit Exam</button>
            </div>
        </form>
    </div>
</main>

<script>
// Get assignment ID from URL
const assignmentId = window.location.pathname.split('/')[2];
let attemptId = '';
let endTime = null;
let timerInterval = null;

// Load exam and questions
async function loadExamData() {
  try {
    const response = await fetch(`/api/${assignmentId}/start`, { method: 'POST' });
    if (!response.ok) throw new Error(`HTTP Error: ${response.status}`);
    const data = await response.json();
    
    console.log('Exam data received:', data);
    
    if (data.exam && data.attempt) {
      const exam = data.exam;
      attemptId = data.attempt.attempt_id;
      document.getElementById('attemptId').value = attemptId;
      document.getElementById('examTitle').textContent = exam.exam_title;
      document.getElementById('examCode').textContent = `Exam Code: ${exam.exam_code}`;
      
      // Calculate end time
      const durationMs = exam.duration_min * 60 * 1000;
      endTime = new Date().getTime() + durationMs;
      
      // Load questions
      loadQuestions(data.questions || []);
      
      // Start timer
      startTimer();
    } else {
      throw new Error('Invalid response format: missing exam or attempt data');
    }
  } catch (error) {
    console.error('Error loading exam:', error);
    document.getElementById('questionContainer').innerHTML = `<div style="color:#ef4444; padding:2rem; text-align:center;">Error loading exam: ${error.message}</div>`;
  }
}

function loadQuestions(questions) {
  const container = document.getElementById('questionContainer');
  if (!questions || questions.length === 0) {
    container.innerHTML = '<div style="color:#6b7280; padding:2rem; text-align:center;">No questions available</div>';
    return;
  }
  
  container.innerHTML = questions.map((q, idx) => `
    <div class="modern-question-card" data-question-id="${q.question_id}">
      <div class="modern-card-header">
        <h5>Question ${idx + 1}</h5>
        <span class="points-badge">${q.points} points</span>
      </div>
      <div class="modern-card-body">
        <p class="question-text">${q.body_text}</p>
        ${q.media && q.media.length > 0 ? `
          <div class="question-media mb-3">
            ${q.media.filter(m => m.file_url.match(/\.(jpg|jpeg|png|gif)$/i)).map(m => `
              <img src="/${m.file_url}" class="img-fluid mb-2" alt="Question Image" style="max-width:400px; border-radius:8px;">
            `).join('')}
          </div>
        ` : ''}
        <div class="answer-section">
          ${q.type_id === 1 && q.options ? `
            <div class="mcq-options">
              ${q.options.map((opt, optIdx) => `
                <div class="modern-form-check">
                  <input class="form-check-input" type="radio"
                    name="question_${q.question_id}" 
                    id="option_${opt.option_id}"
                    value="${opt.option_id}"
                    data-question-id="${q.question_id}">
                  <label for="option_${opt.option_id}">
                    ${String.fromCharCode(65 + optIdx)}. ${opt.option_text}
                  </label>
                </div>
              `).join('')}
            </div>
          ` : `
            <div class="form-group">
              <textarea class="modern-textarea" rows="6" 
                data-question-id="${q.question_id}"
                placeholder="Enter your answer here..."></textarea>
            </div>
          `}
        </div>
      </div>
    </div>
  `).join('');
}

function startTimer() {
  if (timerInterval) clearInterval(timerInterval);
  
  function updateTimer() {
    const now = new Date().getTime();
    const timeLeft = endTime - now;
    
    if (timeLeft <= 0) {
      clearInterval(timerInterval);
      document.getElementById('timer').textContent = '00:00';
      submitExam(true);
      return;
    }

    const minutes = Math.floor((timeLeft % (1000 * 60 * 60)) / (1000 * 60));
    const seconds = Math.floor((timeLeft % (1000 * 60)) / 1000);
    document.getElementById('timer').textContent = 
      minutes.toString().padStart(2, '0') + ':' + 
      seconds.toString().padStart(2, '0');
  }

  timerInterval = setInterval(updateTimer, 1000);
  updateTimer();
}

async function submitExam(isAutoSubmit = false) {
  try {
    // Set flag immediately to prevent beforeunload from interfering
    isFormSubmitted = true;
    
    const responses = {};

    document.querySelectorAll('.form-check-input:checked').forEach(radio => {
      const questionId = radio.getAttribute('data-question-id');
      responses[questionId] = {
        selectedOptionId: parseInt(radio.value)
      };
    });

    document.querySelectorAll('.modern-textarea').forEach(textarea => {
      const questionId = textarea.getAttribute('data-question-id');
      if (textarea.value.trim()) {
        responses[questionId] = {
          text: textarea.value.trim()
        };
      }
    });

    console.log('Submitting responses:', responses);

    const formData = new FormData();
    formData.append('responses', JSON.stringify(responses));
    formData.append('isAutoSubmit', isAutoSubmit.toString());

    const response = await fetch(`/api/exams/submit/${attemptId}`, {
      method: 'POST',
      body: formData
    });

    const result = await response.json();
    console.log('Submit response:', result);
    
    if (result.success || result.message) {
      alert(result.message || 'Exam submitted successfully');
      window.location.href = '/exams';
    } else {
      throw new Error(result.message || 'Submit failed');
    }
  } catch (error) {
    console.error('Error submitting exam:', error);
    // Reset flag if submission failed
    isFormSubmitted = false;
    if (!isAutoSubmit) {
      alert('Error submitting exam. Please try again.');
    }
  }
}

document.getElementById('examForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  if (confirm('Are you sure you want to submit this exam? This action cannot be undone.')) {
    await submitExam(false);
  }
});

let isFormSubmitted = false;
window.addEventListener('beforeunload', (e) => {
  if (!isFormSubmitted && attemptId) {
    // Auto-submit exam if user leaves without clicking submit
    isFormSubmitted = true;
    
    const responses = {};

    document.querySelectorAll('.form-check-input:checked').forEach(radio => {
      const questionId = radio.getAttribute('data-question-id');
      responses[questionId] = {
        selectedOptionId: parseInt(radio.value)
      };
    });

    document.querySelectorAll('.modern-textarea').forEach(textarea => {
      const questionId = textarea.getAttribute('data-question-id');
      if (textarea.value.trim()) {
        responses[questionId] = {
          text: textarea.value.trim()
        };
      }
    });

    // Use sendBeacon to ensure request completes even if page unloads
    const formData = new FormData();
    formData.append('responses', JSON.stringify(responses));
    formData.append('isAutoSubmit', 'true');
    
    // Try to send via beacon (best effort, no guarantee of delivery)
    if (navigator.sendBeacon) {
      const blob = new Blob([new URLSearchParams(formData).toString()], { type: 'application/x-www-form-urlencoded' });
      navigator.sendBeacon(`/api/exams/submit/${attemptId}`, blob);
    }
    
    // Also try with fetch using keepalive flag (modern approach)
    fetch(`/api/exams/submit/${attemptId}`, {
      method: 'POST',
      body: formData,
      keepalive: true
    }).catch(err => console.error('Auto-submit error:', err));
    
    e.preventDefault();
    e.returnValue = '';
  }
});

// Initialize on load
document.addEventListener('DOMContentLoaded', loadExamData);
</script>

<%- include('../shared/footer') %>
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script src="/js/script.js"></script>
</body>

</html>