    <script type="text/javascript" src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>
    <script type="text/javascript"
        src="https://cdn.datatables.net/responsive/2.2.9/js/dataTables.responsive.min.js"></script>

    <script>
        async function loadUsers() {
            try {
                const response = await fetch('/api/users');
                if (!response.ok) throw new Error('Failed to load users');
                const data = await response.json();
                const users = data.users || [];
                
                const tbody = document.getElementById('userTableBody');
                
                if (!users || users.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="7" class="py-4 px-6 text-center text-gray-500">No users found</td></tr>';
                    return;
                }
                
                function getRoleColor(role) {
                    switch(role) {
                        case 'admin': return 'background:#22c55e;color:#fff;';
                        case 'teacher': return 'background:#ef4444;color:#fff;';
                        case 'student': return 'background:#f59e0b;color:#fff;';
                        default: return 'background:#9ca3af;color:#fff;';
                    }
                }
                
                tbody.innerHTML = users.map(user => `
                    <tr class="border-b border-gray-200 hover:bg-gray-50">
                        <td class="py-3 px-6">${user.id}</td>
                        <td class="py-3 px-6">${user.username}</td>
                        <td class="py-3 px-6">
                            <span class="px-2 py-1 text-xs rounded-full font-semibold" style="${getRoleColor(user.role)}">
                                ${user.role.charAt(0).toUpperCase() + user.role.slice(1)}
                            </span>
                        </td>
                        <td class="py-3 px-6">${user.full_name || 'N/A'}</td>
                        <td class="py-3 px-6">${user.email || 'N/A'}</td>
                        <td class="py-3 px-6">${user.phone || 'N/A'}</td>
                        <td class="py-3 px-6 text-center">
                            <a href="/users/${user.id}/edit" class="text-blue-500 hover:text-blue-700 mr-2" title="Edit"><i class="fas fa-edit"></i></a>
                            <button onclick="deleteUser(${user.id})" class="text-red-500 hover:text-red-700" title="Delete"><i class="fas fa-trash-alt"></i></button>
                        </td>
                    </tr>
                `).join('');
                
                // Reinitialize DataTable
                if ($.fn.dataTable.isDataTable('#userTable')) {
                    $('#userTable').DataTable().destroy();
                }
                
                $('#userTable').DataTable({
                    responsive: true,
                    pageLength: 10,
                    language: {
                        search: "Search users:",
                        lengthMenu: "Show _MENU_ users per page",
                        info: "Showing _START_ to _END_ of _TOTAL_ users",
                        paginate: {
                            first: "First",
                            last: "Last",
                            next: "Next",
                            previous: "Previous"
                        }
                    }
                });
            } catch (error) {
                console.error('Error loading users:', error);
                document.getElementById('userTableBody').innerHTML = '<tr><td colspan="7" class="py-4 px-6 text-center text-red-500">Error loading users</td></tr>';
            }
        }
        
        async function deleteUser(userId) {
            if (confirm('Are you sure you want to delete this user?')) {
                try {
                    const response = await fetch(`/api/users/${userId}`, { method: 'DELETE' });
                    if (response.ok) {
                        loadUsers();
                    } else {
                        const error = await response.json();
                        alert(error.error || 'Failed to delete user');
                    }
                } catch (error) {
                    alert('Error deleting user');
                }
            }
        }
        
        $(document).ready(loadUsers);
    </script>

